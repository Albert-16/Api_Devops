using Domain.Entities;
using Domain.Entities.CYBERPGM;
using EasyTemplateSolution.DistributedServices.WsdlSunitpClient.Services;
using EasyTemplateSolution.Domain.ARepositories;
using EasyTemplateSolution.Domain.Dto;
using EasyTemplateSolution.Infrastructure.DataModels;
using EasyTemplateSolution.Infrastructure.Repository;
using System.Collections.Generic;

namespace Infraestructure.Repositories
{
    public class ConversionCompraVentaRepository : AEasyDataProcessRepository
    {
        public ConversionCompraVentaRepository() { }

        public override bool NeedDataBaseConnection
        {
            get { return true; }
        }

        public override Data DoProcess(ISunitpService _sunitpService, Data data)
        {
            var dataResponse = new Data();
            dataResponse.Error = "0000000000000000000";
            dataResponse.HasData = true;
            dataResponse.Field = "RESPONSE";
            dataResponse.ExternalError = "PROCESO REALIZADO CORRECTAMENTE";
            dataResponse.InternalError = "";
            dataResponse.DataList = new List<Data>();

            if (!data.Field.Equals("REQUEST_DETAIL"))
            {
                dataResponse.Error = "10000000000000000007";
                dataResponse.ExternalError = "NO SE HAN ENCONTRADO LOS PARAMETROS NECESARIOS PARA EL REQUEST.";
                return dataResponse;
            }

            //MapRequest
            var cyb00027cl = new CYB00027CL();
            var cyb00027clResponse = new CYB00027CLResponse();
            var cyb00027clHeader = new CYB00027CLHeader();
            var fQuery = new FieldsQuery();

            var rom = new RequestObjectMapper();
            rom.Map(cyb00027cl, data);
            _sunitpService.AddObjLog("ConversionCompraVenta DoProcess", "00000000000000000000", "OBJETO ENVIADO", cyb00027cl.GetObject());


            //crear encabezado de lista "Registros"
            var codMsgRespuesta = 0;
            var lista = new Data();
            lista.Field = "Registros";
            lista.DataList = new List<Data>();


            foreach (var item in data.DataList)
            {
                if (item.Field.Equals("Registros"))
                {

                    var i = 0;
                    var registros = item;
                    foreach (var registro in registros.DataList)
                    {

                        i += 1;
                        if (registro.Field.Equals("Registro"))
                        {
                            var dataConversion = registro;

                            var romList = new RequestObjectMapper();
                            romList.Map(cyb00027cl, dataConversion);

                        }


                        //CallModel
                        var edm = new EasyDataModels();
                        edm.EasyCallInit(_oledbConnection, cyb00027cl);
                        edm.CallProcedure();
                        _sunitpService.AddObjLog("ConversionCompraVenta DoProcess", "00000000000000000000", "OBJETO RECIBIDO", cyb00027cl.GetObject());


                        codMsgRespuesta = int.Parse(cyb00027cl.GetValue("codMsgRespuesta"));

                        if (edm.IsSuccessful())
                        {
                            var numBank = fQuery.fieldQuery("CUXBK", "1");
                            var numProduct = fQuery.fieldQuery("CUX1AC", cyb00027cl.GetValue("valNumeroProducto"));


                            //setear valores de cyb00027cl a cyb00027clHeader y cyb00027clResponse
                            foreach (var items in cyb00027cl.GetParameters())
                            {
                                var key = items.Key;
                                var easy = items.Value;

                                cyb00027clHeader.SetValue(key, easy.value);
                                cyb00027clResponse.SetValue(key, easy.value);
                            }


                            cyb00027clHeader.SetValue("codMsgRespuesta", codMsgRespuesta.ToString());

                            if (codMsgRespuesta == 0)
                            {
                                //Response Data Mapper
                                var rdmResponse = new ResponseDataMapper(i.ToString(), "Registro", "", "", "", "");
                                var response = rdmResponse.Map(cyb00027clResponse);

                                //agregar lista a encabezado
                                lista.HasData = true;
                                lista.DataList.Add(response);
                            }
                            else
                            {

                                break;
                            }

                        }

                        else
                        {
                            dataResponse.Error = "10000000000000000005";
                            dataResponse.ExternalError = "ERROR AL MOMENTO DE LLAMAR AL PROCEDIMIENTO ALMACENADO.";
                            dataResponse.InternalError = cyb00027cl.GetValue("_defaultError");
                        }

                    }

                }
            }

            var rdm = new ResponseDataMapper("", "RESPONSE", "", "00000000000000000000", "PROCESO REALIZADO EXITOSAMENTE", "");
            dataResponse = rdm.Map(cyb00027clHeader);

            if (codMsgRespuesta == 0)
            {
                dataResponse.DataList.Add(lista);
            }

            _sunitpService.AddObjLog("ConversionCompraVenta DoProcess", "00000000000000000000", "OBJETO ENVIADO", cyb00027cl.GetObject());
            return dataResponse;

        }
    }
}
