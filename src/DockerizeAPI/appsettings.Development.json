{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "Build": {
    "TempDirectory": "./tmp/dockerize-builds",
    "UseWsl": true,
    "SharedFilesPath": "./shared-files"
  },
  "Server": {
    "Urls": "http://localhost:5050",
    "EnableSwagger": true
  }
}
